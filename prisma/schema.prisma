generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Post {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  coverImage  String?
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  readingTime Int       @default(0)
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tags        PostTag[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  color String    @default("#6366f1")
  posts PostTag[]
}

model PostTag {
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  String

  @@id([postId, tagId])
}

model SiteSettings {
  id          String @id @default("settings")
  title       String @default("Mi Blog")
  description String @default("Un blog sobre tecnología y programación")
  authorName  String @default("Admin")
  authorBio   String @default("")
  authorImage String @default("")
  twitterUrl  String @default("")
  githubUrl   String @default("")
  linkedinUrl String @default("")
}
