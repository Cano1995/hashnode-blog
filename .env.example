# Base de datos (SQLite en desarrollo, cambia a PostgreSQL en producción)
DATABASE_URL="file:./dev.db"

# URL pública del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL="https://tudominio.com"

# NextAuth — genera uno con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-una-clave-segura-de-32-caracteres"

# Credenciales del panel de administración
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="cambia-esta-contraseña"

# SMTP de Hostinger para envío de emails
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_USER="tu-correo@tudominio.com"
SMTP_PASS="contraseña-del-correo"
SMTP_FROM="tu-correo@tudominio.com"
